    "resource.limit": {
      "sounds": [
        {
          "file": "sounds/vo_klee_life_die_02.wav",
          "label": "可莉…想回家了…"
        },
        {
          "file": "sounds/vo_klee_life_less30_03.wav",
          "label": "玩累了，有点晕…"
        }
      ]
    },
    "user.spam": {
      "sounds": [
        {
          "file": "sounds/vo_klee_life_less30_teammate_01.wav",
          "label": "火花骑士，爆破支援！"
        },
        {
          "file": "sounds/vo_klee_dialog_close.mp3",
          "label": "能不能帮我隐瞒一下…"
        }
      ]
    },
    "session.end": {
      "sounds": [
        {
          "file": "sounds/vo_klee_dialog_greetingNight2.mp3",
          "label": "天黑以后…拜托你回去的时候，把我也送回家好不好…"
