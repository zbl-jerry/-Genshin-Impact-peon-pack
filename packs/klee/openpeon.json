    "task.error": {
      "sounds": [
        {
          "file": "sounds/vo_klee_battle_hit_H_02.wav",
          "label": "好疼啊！"
        },
        {
          "file": "sounds/vo_klee_life_less30_01.wav",
          "label": "哇…怎么会这样…"
        }
      ]
