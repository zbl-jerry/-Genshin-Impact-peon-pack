    "task.acknowledge": {
      "sounds": [
        {
          "file": "sounds/vo_klee_battle_skill1_01.wav",
          "label": "蹦蹦炸弹！"
        },
        {
          "file": "sounds/vo_klee_battle_skill3_01.wav",
          "label": "轰轰火花！"
        },
        {
          "file": "sounds/vo_klee_life_less30_teammate_02.wav",
          "label": "你不要紧吧？"
        }
      ]
    },
    "task.complete": {
      "sounds": [
        {
          "file": "sounds/vo_klee_chest_open_02.wav",
          "label": "亮闪闪的，好开心！"
        },
        {
          "file": "sounds/vo_klee_battle_skill3_02.wav",
