        },
        {
          "file": "sounds/vo_citlali_battle_skill3_01.wav",
          "label": "灭口交给你们俩了！"
        },
        {
          "file": "sounds/vo_citlali_battle_skill1_01.wav",
          "label": "出来干活！"
        }
      ]
    },
    "task.complete": {
      "sounds": [
        {
          "file": "sounds/vo_citlali_chest_open_01.wav",
          "label": "挺好的，收下吧"
        },
        {
          "file": "sounds/vo_citlali_battle_skill3_02.wav",
          "label": "茜特菈琳、伊兹帕帕，给我上！"
        },
        {
          "file": "sounds/vo_citlali_chest_open_02.wav",
          "label": "先收下，答谢诸星的祈祷我替你做"
        }
      ]
    },
    "task.error": {
      "sounds": [
        {
          "file": "sounds/vo_citlali_battle_hit_H_01.wav",
          "label": "好胆子！"
        },
        {
          "file": "sounds/vo_citlali_battle_hit_H_02.wav",
          "label": "疼疼！"
        }
      ]
    },
    "input.required": {
      "sounds": [
        {
          "file": "sounds/vo_citlali_dialog_annoyed_01.wav",
          "label": "看起来什么都不在乎只是我的保护色，其实我什么都很在乎"
        },
        {
          "file": "sounds/vo_citlali_life_less30_02.wav",
          "label": "唉，想回家啊"
        }
      ]
    },
    "resource.limit": {
      "sounds": [
        {
          "file": "sounds/vo_citlali_life_less30_03.wav",
          "label": "不能…在你面前…"
        },
        {
          "file": "sounds/vo_citlali_life_less30_01.wav",
          "label": "不该出门的…"
        }
      ]
