{
  "cesp_version": "1.0",
  "name": "hutao",
  "display_name": "胡桃 / Hu Tao",
  "version": "1.0.0",
  "description": "往生堂堂主胡桃，古灵精怪，顺口溜台词，热情豁达的生死观。",
  "author": {
    "name": "yuanshen-sound-pack",
    "github": "yuanshen-sound-pack"
