          "icon": "icons/charlotte_01.jpg"
        },
        {
          "file": "sounds/vo_charlotte_dialog_greetingNoon.wav",
          "label": "是午饭时间了呀，我知道一家餐厅很不错，跟我来吧",
          "icon": "icons/charlotte_02.jpg"
        }
      ]
