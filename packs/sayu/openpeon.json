        },
        {
          "file": "sounds/vo_sayu_dialog_greetingNoon.wav",
          "label": "好困，午睡时间还不到吗？"
        },
        {
          "file": "sounds/vo_sayu_character_idle_01.mp3",
          "label": "呼啊…呼噜呼噜——"
        }
      ]
    },
    "task.acknowledge": {
      "sounds": [
        {
          "file": "sounds/vo_sayu_battle_skill3_02.wav",
          "label": "出来吧！"
        },
        {
          "file": "sounds/vo_sayu_battle_skill1_04.wav",
          "label": "极意遁走"
        },
        {
          "file": "sounds/vo_sayu_battle_skill3_01.wav",
          "label": "分身之术"
        }
      ]
    },
    "task.complete": {
      "sounds": [
        {
          "file": "sounds/vo_sayu_chest_open_02.wav",
          "label": "大丰收！可以睡觉了吗？"
        },
        {
          "file": "sounds/vo_sayu_battle_skill1_05.wav",
          "label": "抓不住我…呜"
        },
        {
          "file": "sounds/vo_sayu_chest_open_01.wav",
          "label": "这个箱子…好像可以睡进去"
        }
      ]
    },
    "task.error": {
      "sounds": [
        {
          "file": "sounds/vo_sayu_battle_hit_H_02.wav",
          "label": "呜，要晕倒了"
        },
        {
          "file": "sounds/vo_sayu_life_die_03.wav",
          "label": "不该偷懒的…"
        }
      ]
    },
    "input.required": {
      "sounds": [
        {
          "file": "sounds/vo_sayu_character_idle_02.wav",
          "label": "工作还不如睡觉"
        },
        {
          "file": "sounds/vo_sayu_life_less30_02.wav",
          "label": "头晕乎乎的"
        }
      ]
    },
    "resource.limit": {
      "sounds": [
        {
          "file": "sounds/vo_sayu_life_less30_03.wav",
          "label": "呼，好累"
        },
        {
          "file": "sounds/vo_sayu_dialog_idle.mp3",
          "label": "一直拖着不做，就会有更合适的人去做"
        }
      ]
