    "user.spam": {
      "sounds": [
        {
          "file": "sounds/vo_sayu_life_less30_teammate_02.wav",
          "label": "先退下休息"
        },
        {
          "file": "sounds/vo_sayu_life_less30_teammate_01.wav",
          "label": "我来掩护"
        }
      ]
