    "session.end": {
      "sounds": [
        {
          "file": "sounds/vo_sayu_dialog_greetingNight.wav",
          "label": "确认完毕，方圆十里内没有巫女姐姐。今晚可以睡个好觉啦~"
        },
        {
          "file": "sounds/vo_sayu_dialog_greetingNight2.wav",
          "label": "终于…可以睡觉了…晚…晚安…"
